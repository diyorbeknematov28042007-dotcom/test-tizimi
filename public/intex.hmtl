const express = require('express');
const mongoose = require('mongoose');
const path = require('path');
const app = express();

app.use(express.json());
app.use(express.static('public')); // 'public' papkasidagi hamma HTMLlarni ko'rish imkonini beradi

// 1. MONGODB ULANISHI (O'zingizning parolingizni kiritishni unutmang!)
